{
	"name": "twitter-bookmarklets",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"ogp": "bun scripts/generate-ogp.ts",
		"build": "tsc -b && vite build",
		"deploy": "bun run build && wrangler deploy",
		"deploy:dry": "bun run build && wrangler deploy --dry-run",
		"cf:dev": "bun run build && wrangler dev",
		"lint": "oxlint",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"preview": "vite preview"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"lucide-react": "^1.25.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-icons": "^5.7.0",
		"react-router-dom": "^7.18.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2"
	},
	"devDependencies": {
		"@resvg/resvg-js": "^2.6.2",
		"@tailwindcss/vite": "^4.3.3",
		"@types/node": "^24.13.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"oxfmt": "^0.59.0",
		"oxlint": "^1.71.0",
		"satori": "^0.28.0",
		"tailwindcss": "^4.3.3",
		"typescript": "~6.0.2",
		"vite": "^8.1.1",
		"vite-plugin-sitemap": "^0.8.2",
		"wrangler": "^4.112.0"
	},
	"packageManager": "bun@1.3.14"
}
