{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "twitter-bookmarklets",
	"compatibility_date": "2026-07-18",
	"workers_dev": true,
	"preview_urls": true,
	"assets": {
		"directory": "./dist",
		"not_found_handling": "single-page-application",
	},
	"routes": [
		{
			"pattern": "twitter-bookmarklets.com",
			"custom_domain": true,
		},
	],
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
	},
}
